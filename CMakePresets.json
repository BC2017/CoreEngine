{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 22,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs-debug",
      "displayName": "Visual Studio Debug",
      "generator": "Visual Studio 18 2026",
      "binaryDir": "${sourceDir}/build/vs-debug",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;RelWithDebInfo;Release",
        "HFENGINE_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "vs-validation",
      "displayName": "Visual Studio Validation",
      "inherits": "vs-debug",
      "binaryDir": "${sourceDir}/build/vs-validation",
      "cacheVariables": {
        "HFENGINE_WARNINGS_AS_ERRORS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "vs-debug",
      "configurePreset": "vs-debug",
      "configuration": "Debug"
    },
    {
      "name": "vs-validation",
      "configurePreset": "vs-validation",
      "configuration": "Debug"
    }
  ],
  "testPresets": [
    {
      "name": "vs-debug",
      "configurePreset": "vs-debug",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "vs-unit",
      "configurePreset": "vs-debug",
      "configuration": "Debug",
      "filter": {
        "include": {
          "label": "unit"
        }
      },
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
